{
  "name": "feishu-agent-bridge",
  "version": "1.2.6",
  "description": "飞书/Lark 与任意 AI Agent 的 Node.js 桥接（WebSocket / HTTP Webhook、消息收发）；可与 Cursor Headless、Claude Code、自建服务等集成",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./gateway": {
      "types": "./dist/feishu/gateway.d.ts",
      "default": "./dist/feishu/gateway.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "release": "bumpp"
  },
  "author": "yucheng1207",
  "repository": {
    "type": "git",
    "url": "https://github.com/yucheng1207/feishu-agent-bridge"
  },
  "homepage": "https://github.com/yucheng1207/feishu-agent-bridge#readme",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.56.1",
    "http-proxy-agent": "^8.0.0",
    "https-proxy-agent": "^7.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bumpp": "^10.4.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "feishu",
    "lark",
    "飞书",
    "飞书机器人",
    "agent",
    "ai",
    "chatbot",
    "websocket",
    "webhook",
    "cursor",
    "claude"
  ],
  "license": "MIT"
}
